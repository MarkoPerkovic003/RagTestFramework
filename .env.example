
# ── Syntax AI Studio RAG-Agent (Prüfobjekt) ───────────────────────────────────
# API-Key aus dem Syntax AI Studio Portal
SYNTAX_AGENT_API_KEY=sk-5-YOUR_API_KEY_HERE
# RAG-Agent-URL aus dem Syntax AI Studio Portal
SYNTAX_AGENT_URL=https://studio-api.ai.syntax-rnd.com/api/v1/agents/YOUR_AGENT_ID/invoke

# ── Syntax AI Studio Judge-Agent (GPT Chat) ───────────────────────────────────
# Wird als LLM-Judge für RAGAS und LLMJudge verwendet
JUDGE_AGENT_URL=https://studio-api.ai.syntax-rnd.com/api/v1/agents/YOUR_JUDGE_AGENT_ID/invoke
# Falls der Judge-Agent denselben API-Key verwendet wie der RAG-Agent, leer lassen
JUDGE_AGENT_API_KEY=

# ── Welchen RAG-Agent testen? ──────────────────────────────────────────────────
# "demo"   = lokale ChromaDB-Pipeline (kein Syntax-Key nötig)
# "syntax" = echter Syntax AI Studio Agent
RAG_TARGET=syntax

# ── Anthropic API (für LLM-Varianten-Generator + Judge-Fallback) ──────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# ── Optionale Modell-Einstellungen ────────────────────────────────────────────
# GENERATOR_MODEL=claude-sonnet-4-6   (nur für demo-Modus)
# JUDGE_MODEL=claude-opus-4-6         (Fallback wenn JUDGE_AGENT_URL leer)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
